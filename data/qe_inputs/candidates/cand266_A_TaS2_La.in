&CONTROL
    calculation = 'scf'
    prefix      = 'cand266_A_TaS2_La'
    pseudo_dir  = '/root/qe_pseudos'
    outdir      = '/root/qe_scratch'
    verbosity   = 'low'
    tprnfor     = .true.
    tstress     = .true.
    nstep       = 60
    forc_conv_thr = 1.0d-3
    etot_conv_thr = 1.0d-5
/
&SYSTEM
