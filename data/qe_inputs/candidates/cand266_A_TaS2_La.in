    degauss     = 0.01

/
&ELECTRONS
    conv_thr        = 1.0d-7
    mixing_beta     = 0.4
    electron_maxstep = 200
    diagonalization = 'david'
/
&IONS
    ion_dynamics = 'bfgs'
/

