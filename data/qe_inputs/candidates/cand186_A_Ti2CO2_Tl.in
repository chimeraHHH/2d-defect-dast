&CONTROL
    calculation = 'scf'
    prefix      = 'cand186_A_Ti2CO2_Tl'
    pseudo_dir  = '/root/qe_pseudos'
    outdir      = '/root/qe_scratch'
    verbosity   = 'low'
    tprnfor     = .true.
    tstress     = .true.
    nstep       = 60
    forc_conv_thr = 1.0d-3
    etot_conv_thr = 1.0d-5
/
&SYSTEM
    ibrav   = 0
    nat     = 81
    ntyp    = 4
    ecutwfc = 50.0
    ecutrho = 400.0
    occupations = 'smearing'
    smearing    = 'mp'
    degauss     = 0.01

/
&ELECTRONS
    conv_thr        = 1.0d-7
    mixing_beta     = 0.4
    electron_maxstep = 200
    diagonalization = 'david'
/
&IONS
    ion_dynamics = 'bfgs'
/

