&CONTROL
    calculation = 'scf'
    prefix      = 'cand074_B_BiITe_Ba'
    pseudo_dir  = '/root/qe_pseudos'
    outdir      = '/root/qe_scratch'
    verbosity   = 'low'
    tprnfor     = .true.
    tstress     = .true.
    nstep       = 60
